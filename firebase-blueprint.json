{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for rider or driver",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["rider", "driver"] },
        "phoneNumber": { "type": "string" },
        "currentLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "timestamp": { "type": "string", "format": "date-time" }
          }
        },
        "isActive": { "type": "boolean", "description": "For drivers: ready to take rides" },
        "activeRideId": { "type": "string", "description": "ID of the ride user is currently involved in" }
      },
      "required": ["uid", "email", "role"]
    },
    "Ride": {
      "title": "Ride",
      "description": "A taxi ride request and its state",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "riderId": { "type": "string" },
        "riderName": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "pickup": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "destination": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "status": {
          "type": "string",
          "enum": ["requested", "accepted", "ongoing", "completed", "cancelled"]
        },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "fare": { "type": "number" }
      },
      "required": ["riderId", "pickup", "destination", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and real-time state"
    },
    "/rides/{rideId}": {
      "schema": "Ride",
      "description": "Ride transactions and tracking"
    }
  }
}
